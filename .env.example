# ===========================================================================
# ABYSS — Environment configuration
# Copy this file to ".env"  ->  (PowerShell)  Copy-Item .env.example .env
# ===========================================================================

# Data source for the app.
#   "memory"  -> uses built-in sample data (NO database needed). Great for design/dev.
#   "prisma"  -> uses the real database via Prisma (MySQL on XAMPP).
DATA_SOURCE="memory"

# MySQL connection (XAMPP default). Create a database named "abyss" in phpMyAdmin first.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@127.0.0.1:3306/abyss"

# Simple admin gate (demo only — replace with real auth for production)
ADMIN_PASSWORD="abyss-admin"
