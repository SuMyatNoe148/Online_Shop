# ===========================================================================
# ABYSS — Environment configuration
# Copy this file to ".env"  ->  (PowerShell)  Copy-Item .env.example .env
# ===========================================================================

# Data source for the app.
#   "memory"  -> uses built-in sample data (NO database needed). Great for design/dev.
#   "prisma"  -> uses the real database via Prisma (MySQL on XAMPP).
DATA_SOURCE="memory"

# MySQL connection (XAMPP default). Create a database named "abyss" in phpMyAdmin first.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@127.0.0.1:3306/abyss"

# Simple admin gate (demo only — replace with real auth for production)
ADMIN_PASSWORD="abyss-admin"

# ===========================================================================
# PHP API configuration (php-api/) — read by php-api/env.php
# ===========================================================================

# Auth token signing secret (HMAC-SHA256). Change to a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-secret"

# CORS: comma-separated allowed origins, or * for any (dev default).
CORS_ALLOWED_ORIGINS="*"

# MySQL connection used by the PHP API.
DB_HOST="localhost"
DB_NAME="abyss"
DB_USER="abyss_user"
DB_PASS="abyss2024"
DB_CHARSET="utf8mb4"

# ---- MMPay payment gateway -------------------------------------------------
# Leave these blank to run in SANDBOX mode (demo MMQR + simulated success).
# Fill them in from your MMPay Dashboard to go live.
MMPAY_APP_ID=""
MMPAY_PUBLISHABLE_KEY=""
MMPAY_SECRET_KEY=""
MMPAY_API_BASE_URL="https://api.myanmyanpay.com"
# Seconds the sandbox waits before auto-confirming a payment (demo only).
MMPAY_SANDBOX_CONFIRM_SECONDS="8"

# ===========================================================================
# Frontend (Next.js) — must be prefixed with NEXT_PUBLIC_ to reach the browser
# ===========================================================================
NEXT_PUBLIC_PHP_API_URL="http://localhost/Abyss.Net/php-api"
